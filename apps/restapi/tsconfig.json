{
    "extends": "@ocmo/typescript-config/base.json",
    "compilerOptions": {
        "ignoreDeprecations": "6.0",
        "outDir": "/.dist",
        "rootDir": "./src",
        "baseUrl": ".",
        "paths": {
            "@/*": [
                "src/*"
            ]
        }
    },
    "include": [
        "src/**/*.ts",
        "src/**/*.json"
    ],
    "exclude": [
        "node_modules",
        "dist"
    ]
}